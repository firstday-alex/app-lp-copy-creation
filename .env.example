# Anthropic key — SERVER-SIDE ONLY, never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Postgres connection string. Added automatically when you attach a
# Postgres store to the project in the Vercel dashboard (Storage tab).
POSTGRES_URL=postgres://...

# Optional shared access token. If set, the app asks for it once (Settings) and
# sends it on every API call. Leave blank to keep the app open and rely on
# Vercel deployment protection instead.
APP_ACCESS_TOKEN=
